    <style>
        :root {
            --gold-leaf: #d4af37;
            --gold-glow: rgba(212, 175, 55, 0.4);
            --liturgical-blue: #0a192f;
            --legal-black: #050505;
            --marble-white: #f8f9fa;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            font-family: 'Montserrat', sans-serif; 
            background: url('https://www.transparenttextures.com/patterns/white-marble.png'), var(--marble-white);
            color: var(--legal-black); 
            line-height: 1.8; 
        }

        /* PERSISTENT ULTRA-SLIM HEADER (60PX) */
        header {
            background: var(--legal-black);
            position: sticky;
            top: 0;
            z-index: 3000;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            border-bottom: 4px solid var(--gold-leaf);
            height: 60px; 
            padding: 0 5%;
        }

        .floating-logo-anchor { 
            position: absolute;
            left: 5%;
            top: 0;
            height: 0; 
        }

        .floating-logo-anchor img { 
            height: 320px; 
            width: auto; 
            filter: drop-shadow(0 0 15px var(--gold-glow));
            animation: divine-glow 5s infinite ease-in-out;
        }

        @keyframes divine-glow {
            0%, 100% { filter: drop-shadow(0 0 10px var(--gold-glow)); transform: translateY(0); }
            50% { filter: drop-shadow(0 0 30px var(--gold-leaf)); transform: translateY(5px); }
        }

        nav.top-nav { display: flex; gap: 30px; }
        nav.top-nav a { 
            color: white; 
            text-decoration: none; 
            font-weight: 700; 
            font-size: 0.7rem; 
            text-transform: uppercase; 
            letter-spacing: 2.5px;
            font-family: 'Cinzel', serif;
        }

        /* HERO: THE LIBRARY OF ADHERENCE */
        .library-hero {
            padding: 280px 10% 120px;
            background: linear-gradient(rgba(10, 25, 47, 0.94), rgba(10, 25, 47, 0.94)), url('philly-law-library-archive.jpg');
            background-attachment: fixed;
            background-size: cover;
            text-align: center;
            border-bottom: 12px solid var(--gold-leaf);
            clip-path: polygon(0 0, 100% 0, 100% 90%, 50% 100%, 0 90%);
        }

        h1 { font-family: 'Cinzel', serif; font-size: 3.5rem; color: white; letter-spacing: 5px; }
        .vault-sub { font-family: 'Playfair Display', serif; color: var(--gold-leaf); font-size: 1.4rem; font-style: italic; margin-top: 10px; }

        .vault-container { max-width: 1100px; margin: -50px auto 100px; padding: 0 20px; position: relative; z-index: 10; }
        
        .vault-scroll {
            background: white;
            border: 1px solid var(--gold-leaf);
            padding: 80px 60px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.15);
        }

        .archive-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }

        .archive-card {
            border: 1px solid #eee;
            padding: 30px;
            background: var(--marble-white);
            transition: 0.3s;
            text-align: left;
        }
        .archive-card:hover { border-color: var(--gold-leaf); transform: translateY(-5px); }
        .archive-card h3 { font-family: 'Cinzel'; color: var(--liturgical-blue); margin-bottom: 15px; border-bottom: 1px solid #ddd; padding-bottom: 10px; }
        .doc-tag { font-family: 'Playfair Display'; font-style: italic; color: var(--gold-leaf); font-size: 0.8rem; display: block; margin-bottom: 10px; }

        .wisdom-banner {
            background: var(--liturgical-blue);
            color: white;
            padding: 60px;
            margin-top: 60px;
            text-align: center;
            border-top: 5px solid var(--gold-leaf);
        }

        footer {
            background: var(--legal-black);
            color: white;
            padding: 100px 5% 50px;
            text-align: center;
            border-top: 15px solid var(--gold-leaf);
        }
    </style>
</head>
